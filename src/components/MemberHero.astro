---
import type { Member } from "../data/members";
import type { Locale } from "../i18n/types";
import { t } from "../i18n/ui";
import { nameFallback } from "../utils/name-fallback";

export interface Props {
  member: Member;
  locale: Locale;
}

const { member, locale } = Astro.props;
const copy = member.content[locale];
const labels = t(locale);
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
const photoUrl = `${base}/${member.photo.replace(/^\//, "")}`;
const photoFallback = nameFallback(copy.displayName);
---

<div class="member-hero">
  <div class="member-photo" data-member-id={member.id}>
    <img
      src={photoUrl}
      alt={copy.displayName}
      onerror="this.setAttribute('hidden','');this.nextElementSibling.removeAttribute('hidden')"
    />
    <div class="member-photo-fallback" hidden aria-hidden="true">{photoFallback}</div>
  </div>
  <div class="member-info">
    <h1>{copy.displayName}</h1>
    <div class="member-name-zh">{copy.alternateName}</div>
    <div class="member-title">{copy.title}</div>
    <a href={`mailto:${member.email}`} class="member-email">{member.email}</a>

    <h4 style="margin-top: var(--spacing-4); margin-bottom: var(--spacing-2);">{labels.education}</h4>
    <ul class="education-list">
      {copy.education.map((edu) => (
        <li>
          <span class="degree">{edu.degree}</span>
          <span class="institution">{edu.institution}</span>
          <span style="color: var(--color-text-secondary); margin-left: auto;">{edu.period}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
