---
import { SITE } from "../config";
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4>OERF Lab</h4>
        <p>
          Optical & Extreme Reaction Flow (OERF) Lab<br />
          {SITE.institute}<br />
          {SITE.school}<br />
          {SITE.university}<br />
          {SITE.address}
        </p>
      </div>
      <div>
        <h4>Quick Links</h4>
        <ul>
          <li><a href={`${base}/research/`}>Research</a></li>
          <li><a href={`${base}/team/`}>Team</a></li>
          <li><a href={`${base}/publications/`}>Publications</a></li>
          <li><a href={`${base}/contact/`}>Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Connect</h4>
        <ul>
          <li><a href="https://www.sjtu.edu.cn" target="_blank" rel="noopener">Shanghai Jiao Tong University</a></li>
          <li><a href="https://me.sjtu.edu.cn" target="_blank" rel="noopener">School of Mechanical Engineering</a></li>
          <li><a href="https://scholar.google.com/citations?user=4mYjOrsAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar (Cai)</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} OERF Lab — Optical & Extreme Reaction Flow. Shanghai Jiao Tong University.</p>
    </div>
  </div>
</footer>
