---
import { SITE } from "../config";
import { localePath, staticRoutes } from "../i18n/routes";
import { t } from "../i18n/ui";
import type { Locale } from "../i18n/types";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = t(locale);
const site = SITE.content[locale];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4>OERF Lab</h4>
        <p>
          {site.title}<br />
          {site.institute}<br />
          {site.school}<br />
          {site.university}<br />
          {site.address}
        </p>
      </div>
      <div>
        <h4>{copy.quickLinks}</h4>
        <ul>
          <li><a href={localePath(locale, staticRoutes.research)}>{copy.research}</a></li>
          <li><a href={localePath(locale, staticRoutes.team)}>{copy.team}</a></li>
          <li><a href={localePath(locale, staticRoutes.publications)}>{copy.publications}</a></li>
          <li><a href={localePath(locale, staticRoutes.contact)}>{copy.contact}</a></li>
        </ul>
      </div>
      <div>
        <h4>{copy.connect}</h4>
        <ul>
          <li><a href="https://www.sjtu.edu.cn" target="_blank" rel="noopener">{site.university}</a></li>
          <li><a href="https://me.sjtu.edu.cn" target="_blank" rel="noopener">{site.school}</a></li>
          <li><a href="https://scholar.google.com/citations?user=4mYjOrsAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar (Cai)</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {site.title} · {site.university}</p>
    </div>
  </div>
</footer>
