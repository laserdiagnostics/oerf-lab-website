---
import HighlightBadge from "./HighlightBadge.astro";
import { boldNames } from "../data/publications";
import type { Publication } from "../data/publications";
import type { Locale } from "../i18n/types";
import { t } from "../i18n/ui";

export interface Props {
  pub: Publication;
  locale: Locale;
}

const { pub, locale } = Astro.props;
const copy = t(locale);
---

<div class="publication-card">
  <div class="pub-authors">
    {pub.authors.map((author, i) => {
      const isBolded = boldNames.some((name) => author.includes(name));
      return (
        <span>
          {i > 0 && ", "}
          {isBolded ? <strong>{author}</strong> : author}
        </span>
      );
    })}
  </div>
  <div class="pub-title">"{pub.title}"</div>
  <div class="pub-journal">
    {pub.journal}
    {pub.volume ? `, ${pub.volume}` : ""}
    {pub.pages ? `, ${pub.pages}` : ""}
    ({pub.year})
  </div>
  {(pub.doi || pub.paperUrl) && (
    <div class="pub-meta">
      <a href={pub.doi ? `https://doi.org/${pub.doi}` : pub.paperUrl} target="_blank" rel="noopener">
        {pub.doi ? `DOI: ${pub.doi}` : copy.viewPaper}
      </a>
      {pub.highlight && <HighlightBadge type={pub.highlight} locale={locale} />}
    </div>
  )}
</div>
