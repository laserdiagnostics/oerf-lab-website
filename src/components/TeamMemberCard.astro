---
import type { Member } from "../data/members";

export interface Props {
  member: Member;
}

const { member } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
const photoUrl = `${base}/${member.photo.replace(/^\//, "")}`;
const memberUrl = `${base}/team/${member.id}/`;
---

<a href={memberUrl} class="team-card">
  <div class="team-card-photo">
    <img
      src={photoUrl}
      alt={`${member.name}`}
      loading="lazy"
      onerror="this.style.display='none';this.parentElement.innerHTML='<div class=photo-fallback>' + this.alt.split(' ').map(function(n){return n[0]}).join('') + '</div>'"
    />
  </div>
  <div class="team-card-body">
    <h3>{member.name}</h3>
    <div class="team-card-title">{member.title}</div>
    <div class="team-card-email">{member.email}</div>
  </div>
</a>
