---
import type { Member } from "../data/members";
import type { Locale } from "../i18n/types";
import { localePath, memberRoute } from "../i18n/routes";
import { nameFallback } from "../utils/name-fallback";

export interface Props {
  member: Member;
  locale: Locale;
}

const { member, locale } = Astro.props;
const copy = member.content[locale];
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
const photoUrl = `${base}/${member.photo.replace(/^\//, "")}`;
const memberUrl = localePath(locale, memberRoute(member.id));
const photoFallback = nameFallback(copy.displayName);
---

<a href={memberUrl} class="team-card">
  <div class="team-card-photo" data-member-id={member.id}>
    <img
      src={photoUrl}
      alt={copy.displayName}
      loading="lazy"
      onerror="this.setAttribute('hidden','');this.nextElementSibling.removeAttribute('hidden')"
    />
    <div class="photo-fallback" hidden aria-hidden="true">{photoFallback}</div>
  </div>
  <div class="team-card-body">
    <h3>{copy.displayName}</h3>
    <div class="team-card-title">{copy.title}</div>
    <div class="team-card-email">{member.email}</div>
  </div>
</a>
