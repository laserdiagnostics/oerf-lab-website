---
import type { ResearchArea } from "../data/research";

export interface Props {
  area: ResearchArea;
}

const { area } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
---

<div class="research-card">
  {area.image && (
    <div class="research-card-media">
      <img
        src={`${base}/images/research/${area.image}`}
        alt={area.imageAlt ?? area.title}
        width={area.imageWidth ?? 1600}
        height={area.imageHeight ?? 900}
        loading="lazy"
        decoding="async"
      />
    </div>
  )}
  <h3>{area.title}</h3>
  <p>{area.summary}</p>
  <div class="research-card-tags">
    {area.highlights.map((h) => (
      <span class="tag">{h}</span>
    ))}
  </div>
</div>
