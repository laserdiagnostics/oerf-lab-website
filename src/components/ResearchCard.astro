---
import type { ResearchArea } from "../data/research";
import type { Locale } from "../i18n/types";

export interface Props {
  area: ResearchArea;
  locale: Locale;
}

const { area, locale } = Astro.props;
const copy = area.content[locale];
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
---

<div class="research-card">
  {area.image && (
    <div class="research-card-media">
      <img
        src={`${base}/images/research/${area.image}`}
        alt={copy.imageAlt}
        width={area.imageWidth ?? 1600}
        height={area.imageHeight ?? 900}
        loading="lazy"
        decoding="async"
      />
    </div>
  )}
  <h3>{copy.title}</h3>
  <p>{copy.summary}</p>
  <div class="research-card-tags">
    {copy.highlights.map((h) => (
      <span class="tag">{h}</span>
    ))}
  </div>
</div>
