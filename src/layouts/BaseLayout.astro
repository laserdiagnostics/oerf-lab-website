---
import { SITE } from "../config";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { absoluteAssetUrl, localeAbsoluteUrl } from "../i18n/routes";
import type { ActiveRoute } from "../i18n/routes";
import { htmlLang } from "../i18n/types";
import type { Locale } from "../i18n/types";
import interLatinUrl from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import "../styles/global.css";

export interface Props {
  locale: Locale;
  activeRoute: ActiveRoute;
  routePath: string;
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  locale,
  activeRoute,
  routePath,
  title,
  description,
  ogImage,
  noindex = false,
} = Astro.props;

const site = SITE.content[locale];
const pageTitle = `${title} | ${site.shortName}`;
const pageDesc = description || site.description;
const enUrl = localeAbsoluteUrl("en", routePath);
const zhUrl = localeAbsoluteUrl("zh", routePath);
const pageUrl = locale === "zh" ? zhUrl : enUrl;
const DEFAULT_OG_IMAGE = "/images/og/oerf-lab-share.webp";
const ogImageUrl = absoluteAssetUrl(ogImage ?? DEFAULT_OG_IMAGE);
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
---

<!DOCTYPE html>
<html lang={htmlLang(locale)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    {noindex && <meta name="robots" content="noindex" />}

    <link rel="canonical" href={pageUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <link rel="preload" href={interLatinUrl} as="font" type="font/woff2" crossorigin="anonymous" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={locale === "zh" ? "zh_CN" : "en_US"} />
    <meta property="og:locale:alternate" content={locale === "zh" ? "en_US" : "zh_CN"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ResearchOrganization",
      name: site.shortName,
      description: site.description,
      url: SITE.url,
      parentOrganization: {
        "@type": "CollegeOrUniversity",
        name: site.university,
      },
      location: {
        "@type": "Place",
        address: {
          "@type": "PostalAddress",
          addressLocality: site.addressLocality,
          addressCountry: "CN",
        },
      },
    })}></script>
  </head>
  <body>
    <Navbar locale={locale} activeRoute={activeRoute} routePath={routePath} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
