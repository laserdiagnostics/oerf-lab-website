---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import SectionTitle from "../components/SectionTitle.astro";
import PublicationList from "../components/PublicationList.astro";
import { publications, isPubListed } from "../data/publications";

const selectedPubs = publications.filter(isPubListed);
---

<BaseLayout title="Publications" path="/publications/">
  <HeroSection
    title="Publications"
    subtitle="Journal Publications"
    tagline="Journal publications from the OERF Lab team. Team member names are highlighted in bold."
    compact
  />

  <section class="section">
    <div class="container">
      <SectionTitle
        title="Journal Publications"
        subtitle="Collected from the Google Scholar profiles of Weiwei Cai, Yutao Zheng, Ning Liu, and Shijie Xu; grouped by publication year."
      />
      <PublicationList publications={selectedPubs} />
    </div>
  </section>
</BaseLayout>
