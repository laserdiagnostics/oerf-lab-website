---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ResearchCard from "../components/ResearchCard.astro";
import TeamGrid from "../components/TeamGrid.astro";
import HighlightBadge from "../components/HighlightBadge.astro";
import { researchAreas } from "../data/research";
import { members } from "../data/members";
import { publications, isHomeHighlight } from "../data/publications";

const highlightPubs = publications
  .filter(isHomeHighlight)
  .sort((a, b) => b.year - a.year);

const featuredHighlightConfigs = [
  {
    id: "zhao-nature-electronics-2026",
    image: "memristor-spectrometer-2026.webp",
    mediaClass: "",
    alt: "Conceptual visualization of in situ spectral reconstruction on a memristor chip",
    summary:
      "A fully integrated memristor chip reconstructs spectra directly in the analogue domain, eliminating off-chip data transfer while supporting high-fidelity spectral and hyperspectral imaging.",
    metrics: [
      { value: "125 ns", label: "per spectrum" },
      { value: "6.7 nJ", label: "energy per spectrum" },
      { value: "576 Kb", label: "2T2R memristor array" },
    ],
  },
  {
    id: "liu-nature-synthesis-2026",
    image: "evd-nanomaterials-synthesis-2026.webp",
    mediaClass: "featured-highlight-media-contain",
    alt: "Electrified vapour deposition of multi-element nanomaterials at atmospheric pressure",
    summary:
      "An electrified carbon-paper heater generates an ultrahigh-temperature, high-flux atomic vapour at atmospheric pressure, enabling rapid deposition of multi-element nanomaterials and thin films on a cooler substrate.",
    metrics: [
      { value: "~3,000 K", label: "heater temperature" },
      { value: "10²¹–10²²", label: "atoms cm⁻² s⁻¹ vapour flux" },
      { value: "~0.3 s", label: "stable vapour formation" },
    ],
  },
  {
    id: "cui-science-advances-2025",
    image: "tunable-optoelectronic-interface-2025-v4.webp",
    mediaClass: "featured-highlight-media-diagram",
    alt: "Laboratory visualization of a tunable van der Waals optoelectronic interface for spectral sensing",
    summary:
      "An electrically tunable InSe/NbTe2 van der Waals interface converts diverse optical spectra into distinguishable electrical responses for wavelength sensing and material identification.",
    metrics: [
      { value: "5 × 5 µm", label: "device footprint" },
      { value: "~0.19 nm", label: "free-space accuracy" },
      { value: "~2.45 nm", label: "on-chip accuracy" },
    ],
  },
  {
    id: "liu-nature-2023",
    image: "stable-atmospheric-pressure-plasma-2023.webp",
    mediaClass: "featured-highlight-media-contain",
    paperUrl: "https://www.nature.com/articles/s41586-023-06694-1",
    alt: "Stable atmospheric-pressure plasma generated between carbon-fibre-tip-enhanced electrodes",
    summary:
      "Carbon-fibre-tip-enhanced electrodes merge microspark discharges into a uniform and stable atmospheric-pressure plasma, enabling extreme-temperature materials synthesis in seconds.",
    metrics: [
      { value: "8,000 K", label: "maximum temperature" },
      { value: "~42 V", label: "breakdown voltage" },
      { value: "≥10 min", label: "stable operation" },
    ],
  },
];

const featuredHighlights = featuredHighlightConfigs.flatMap((config) => {
  const pub = highlightPubs.find((candidate) => candidate.id === config.id);
  return pub ? [{ ...config, pub }] : [];
});
const featuredIds = new Set(featuredHighlights.map(({ pub }) => pub.id));
const otherHighlights = highlightPubs
  .filter((pub) => !featuredIds.has(pub.id))
  .slice(0, 3);
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
---

<BaseLayout
  title="Home"
  description="OERF Lab - Optical & Extreme Reaction Flow research group at Shanghai Jiao Tong University. Pioneering optical diagnostics, computational imaging, ultrafast spectroscopy, and reacting flow simulation."
  path=""
>
  <HeroSection
    title="Optical &amp; Extreme Reaction Flow"
    subtitle="OERF Lab"
    tagline="Pioneering optical diagnostics, computational imaging, and reacting flow science for extreme environment energy and propulsion systems at Shanghai Jiao Tong University."
    cta={[
      { text: "Explore Research", href: `${base}/research/` },
      { text: "Meet Our Team", href: `${base}/team/` },
    ]}
  />

  <!-- Team -->
  <section class="section">
    <div class="container">
      <SectionTitle
        title="Our Team"
        subtitle="A cross-disciplinary team of faculty members at the Institute of Turbomachinery, School of Mechanical Engineering."
      />
      <TeamGrid members={members} />
    </div>
  </section>

  <!-- Research Areas -->
  <section class="section">
    <div class="container">
      <SectionTitle
        title="Research Areas"
        subtitle="We develop and apply advanced optical and computational techniques to understand and control extreme reaction flows."
      />
      <div class="research-grid">
        {researchAreas.map((area) => (
          <ResearchCard area={area} />
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Highlights -->
  <section class="section section-alt" id="latest-highlights">
    <div class="container">
      <SectionTitle
        title="Latest Highlights"
        subtitle="Selected high-impact research achievements from our team."
      />

      <div class="featured-highlights">
        {featuredHighlights.map(({ pub, image, mediaClass, paperUrl, alt, summary, metrics }) => (
          <article class="featured-highlight" id={`highlight-${pub.id}`}>
            <a
              class:list={["featured-highlight-media", mediaClass]}
              href={paperUrl ?? `https://doi.org/${pub.doi}`}
              target="_blank"
              rel="noreferrer"
              aria-label={`Read ${pub.title}`}
            >
              <img
                src={`${base}/images/highlights/${image}`}
                alt={alt}
                width="1672"
                height="941"
                loading="lazy"
                decoding="async"
              />
            </a>
            <div class="featured-highlight-content">
              <p class="highlight-eyebrow">{pub.journal} / {pub.year}</p>
              <h3>{pub.title}</h3>
              <p class="featured-highlight-summary">{summary}</p>
              <dl class="highlight-metrics" aria-label="Key performance metrics">
                {metrics.map((metric) => (
                  <div>
                    <dt>{metric.value}</dt>
                    <dd>{metric.label}</dd>
                  </div>
                ))}
              </dl>
              <div class="featured-highlight-actions">
                <a
                  class="btn btn-primary"
                  href={paperUrl ?? `https://doi.org/${pub.doi}`}
                  target="_blank"
                  rel="noreferrer"
                >Read the paper</a>
                <a class="highlight-text-link" href={`${base}/publications/`}>
                  View all publications <span aria-hidden="true">-&gt;</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      {otherHighlights.length > 0 && (
        <div class="more-highlights">
          <h3 class="more-highlights-title">More selected work</h3>
          <div class="highlights-list">
            {otherHighlights.map((pub) => (
              <a
                class="highlight-item"
                href={`https://doi.org/${pub.doi}`}
                target="_blank"
                rel="noreferrer"
              >
                <div class="highlight-year" aria-hidden="true">{pub.year}</div>
                <div class="highlight-content">
                  <h4>{pub.title}</h4>
                  <p>
                    {pub.journal}
                    {pub.highlight && <HighlightBadge type={pub.highlight} />}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
